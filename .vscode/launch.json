{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "CM7_Debug",
            "type": "stlinkgdbtarget",
            "request": "launch", 
            "cwd": "${workspaceFolder}",
            "preBuild": "${command:st-stm32-ide-debug-launch.build}",
            "runEntry": "main",
            "serverShared": true, 
            "serverHaltAllCores": true, 
            "svdPath": "C:/ST/STM32CubeIDE_1.12.1/STM32CubeIDE/plugins/com.st.stm32cube.ide.mcu.productdb.debug_2.2.400.202601091600/resources/cmsis/STMicroelectronics_CMSIS_SVD/STM32H747_CM7.svd", // SVD file for CM7 core
            "imagesAndSymbols": [
                {
                    "imageFileName": "${workspaceFolder}/CM4/build/SmartDrive_CM4.elf" // Loads the CM4.elf image
                },
                {
                    "imageFileName": "${workspaceFolder}/CM7/build/SmartDrive_CM7.elf" // Loads the CM7.elf image
                }
            ],
            "serverInterface": "SWD"
            //"serverReset": "System", // Reset the system when starting this debug session
        },
        {
            "name": "CM4_Debug",
            "type": "stlinkgdbtarget",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "runEntry": "main",
            "serverShared": true,
            "serverApID": "3", 
            "serverPort": "61239", // Port for the GDB server to connect (must be unique if running multiple sessions)
            "serverReset": "None", // No reset when starting this debug session
            "svdPath": "C:/ST/STM32CubeIDE_1.12.1/STM32CubeIDE/plugins/com.st.stm32cube.ide.mcu.productdb.debug_2.2.400.202601091600/resources/cmsis/STMicroelectronics_CMSIS_SVD/STM32H747_CM4.svd", // SVD file for CM4 core
            "imagesAndSymbols": [
                {
                    "symbolFileName": "${workspaceFolder}/CM4/build/SmartDrive_CM4.elf" // Loads the CM4.elf symbols
                }
            ],
            "serverInterface": "SWD"
        }
    ],
    "compounds": [ // Compound configurations allow (attempted) simultaneous debug sessions
    {
      "name": "DualCore_Debug",
      "configurations": ["CM7_Debug", "CM4_Debug"] // List of configurations to launch together
    }
  ]
}